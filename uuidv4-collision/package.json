{
  "name": "uuidv4-collision",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 43000",
    "build": "next build",
    "start": "next start --port 43000",
    "lint": "eslint .",
    "worker": "tsx scripts/uuid-worker.ts",
    "worker:dev": "tsx watch scripts/uuid-worker.ts",
    "docker:build": "pnpm run docker:clean && docker compose build",
    "docker:up": "pnpm run docker:clean && docker compose up --build -d",
    "docker:up:foreground": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down --remove-orphans --rmi local",
    "docker:restart": "docker compose down && docker compose up --build -d",
    "docker:logs": "docker compose logs -f",
    "docker:prod:build": "pnpm run docker:prod:clean && docker compose -f docker-compose.prod.yml build",
    "docker:prod:up": "pnpm run docker:prod:clean && docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:up:foreground": "docker compose -f docker-compose.prod.yml up --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:clean": "docker compose -f docker-compose.prod.yml down --remove-orphans --rmi local",
    "docker:prod:restart": "docker compose -f docker-compose.prod.yml down && docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "worker:docker:build": "pnpm run worker:docker:clean && docker compose build worker",
    "worker:docker:up": "docker compose up --build worker -d",
    "worker:docker:up:foreground": "docker compose up --build worker",
    "worker:docker:down": "docker compose stop worker",
    "worker:docker:restart": "docker compose restart worker",
    "worker:docker:clean": "docker compose rm -f worker",
    "worker:docker:logs": "docker compose logs -f worker",
    "next:docker:build": "pnpm run next:docker:clean && docker compose build web",
    "next:docker:up:foreground": "docker compose up --build web",
    "next:docker:up": "docker compose up --build web -d",
    "next:docker:down": "docker compose stop web",
    "next:docker:restart": "docker compose restart web",
    "next:docker:clean": "docker compose rm -f web",
    "next:docker:logs": "docker compose logs -f web",
    "db:docker:up": "docker compose up -d postgres",
    "db:docker:down": "docker compose stop postgres",
    "db:docker:restart": "docker compose restart postgres",
    "db:docker:clean": "docker compose rm -f postgres",
    "db:docker:reset": "docker compose down --volumes --remove-orphans",
    "db:docker:logs": "docker compose logs -f postgres",
    "db:docker:psql": "docker compose exec postgres psql -U postgres -d uuidv4_collision",
    "db:prod:up": "docker compose -f docker-compose.prod.yml up -d postgres",
    "db:prod:down": "docker compose -f docker-compose.prod.yml stop postgres",
    "db:prod:restart": "docker compose -f docker-compose.prod.yml restart postgres",
    "db:prod:clean": "docker compose -f docker-compose.prod.yml rm -f postgres",
    "db:prod:reset": "docker compose -f docker-compose.prod.yml down --volumes --remove-orphans",
    "db:prod:logs": "docker compose -f docker-compose.prod.yml logs -f postgres",
    "db:prod:psql": "docker compose -f docker-compose.prod.yml exec postgres psql -U postgres -d uuidv4_collision",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@mantine/core": "^9.0.0",
    "@mantine/form": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.0",
    "icons-react,": "link:@tabler/icons-react,",
    "next": "16.2.6",
    "notifications,": "link:@mantine/notifications,",
    "pg": "^8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
