{
  "name": "uuidv4-collision",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "worker": "tsx scripts/uuid-worker.ts",
    "worker:dev": "tsx watch scripts/uuid-worker.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down --volumes --remove-orphans",
    "docker:restart": "docker compose down && docker compose up --build",
    "docker:logs": "docker compose logs -f",
    "worker:docker:build": "docker compose build worker",
    "worker:docker:up": "docker compose up --build worker",
    "worker:docker:down": "docker compose stop worker",
    "worker:docker:restart": "docker compose restart worker",
    "worker:docker:clean": "docker compose rm -f worker",
    "worker:docker:logs": "docker compose logs -f worker",
    "next:docker:build": "docker compose build web",
    "next:docker:up": "docker compose up --build web",
    "next:docker:down": "docker compose stop web",
    "next:docker:restart": "docker compose restart web",
    "next:docker:clean": "docker compose rm -f web",
    "next:docker:logs": "docker compose logs -f web",
    "db:docker:up": "docker compose up -d postgres",
    "db:docker:down": "docker compose stop postgres",
    "db:docker:restart": "docker compose restart postgres",
    "db:docker:clean": "docker compose rm -f postgres",
    "db:docker:logs": "docker compose logs -f postgres",
    "db:docker:psql": "docker compose exec postgres psql -U postgres -d uuidv4_collision",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "dotenv": "^17.4.0",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
