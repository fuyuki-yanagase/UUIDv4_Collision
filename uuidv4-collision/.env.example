# Default host ports for local development and Docker port publishing.
WEB_PORT=43000
POSTGRES_PORT=45432
WORKER_INTERVAL_MS=1000

# PostgreSQL credentials used by Docker Compose.
POSTGRES_DB=uuidv4_collision
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

# Connection string for local tools running on the host machine.
DATABASE_URL=postgresql://postgres:change-this-password@localhost:45432/uuidv4_collision

# Connection string for containers inside Docker Compose.
DATABASE_URL_DOCKER=postgresql://postgres:change-this-password@postgres:5432/uuidv4_collision

# Google Analytics 4 measurement ID. Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console site verification token.
GOOGLE_SITE_VERIFICATION=
